generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(USER)
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile              UserProfile?
  documents            UserDocument[]
  bookings             Booking[]

  @@map("users")
}

model UserProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  photoUrl             String?
  phoneNumber          String?
  address              String?
  idPassportNumber     String?

  emergencyContactName     String?
  emergencyContactEmail    String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  status               UserStatus @default(ACTIVE)
  isDeleted            Boolean    @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("user_profiles")
}

model UserDocument {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      DocumentType
  name      String?        
  path      String         
  status    DocumentStatus @default(PENDING_REVIEW)
  
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("user_documents")
}

model Location {
  id           String         @id @default(uuid())
  name         String
  address      String
  city         String
  locationType LocationType
  status       LocationStatus @default(ACTIVE)
  isDeleted    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  vehicles         Vehicle[]

  // Drop-off charges relations
  pickupCharges    DropOffCharge[] @relation("PickupLocationRelations")
  dropOffCharges   DropOffCharge[] @relation("DropOffLocationRelations")

  // Bookings
  bookingPickups   Booking[]       @relation("BookingPickupLocation")
  bookingDropOffs  Booking[]       @relation("BookingDropOffLocation")

  @@map("locations")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INACTIVE
}

enum DocumentType {
  DRIVERS_LICENSE
  PASSPORT_ID
  KRA_PIN
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum LocationType {
  OFFICE
  AIRPORT
  HOTEL
  PORT
  SHOWROOM
  OTHER
}

enum LocationStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model Vehicle {
  id              String              @id @default(uuid())
  name            String
  category        VehicleCategory
  brand           String
  year            Int
  transmission    VehicleTransmission
  fuelType        VehicleFuelType
  seatingCapacity Int
  luggageCapacity Int?
  description     String?
  features        String[]

  // Pricing
  pricing         Pricing?

  // Status
  status          VehicleStatus       @default(ACTIVE)
  availability    VehicleAvailability @default(AVAILABLE)
  isFeatured      Boolean             @default(false)

  // Location
  locationId      String
  location        Location            @relation(fields: [locationId], references: [id])

  // Images
  images          VehicleImage[]

  // Drivers
  drivers         Driver[]

  // Drop-off charges
  dropOffCharges  DropOffCharge[]

  // Bookings
  bookings        Booking[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("vehicles")
}

model VehicleImage {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  path      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("vehicle_images")
}

enum VehicleCategory {
  SALOON
  SUV
  VAN
  LUXURY
  FOUR_WD
  CHAUFFEUR_DRIVEN
  SELF_DRIVEN
}

enum VehicleTransmission {
  AUTOMATIC
  MANUAL
}

enum VehicleFuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

enum VehicleAvailability {
  AVAILABLE
  RENTED
  MAINTENANCE
}

model Driver {
  id                String             @id @default(uuid())
  name              String
  phoneNumber       String
  whatsappNumber    String
  photoUrl          String?
  licensePhotoUrl   String?
  licenseDetails    String?
  availability      DriverAvailability @default(AVAILABLE)
  notes             String?

  assignedVehicleId String?
  assignedVehicle   Vehicle?           @relation(fields: [assignedVehicleId], references: [id])
  bookings          Booking[]

  isDeleted         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("drivers")
}

enum DriverAvailability {
  AVAILABLE
  ASSIGNED
  UNAVAILABLE
}

model DropOffCharge {
  id                  String              @id @default(uuid())
  
  pickupLocationId    String
  pickupLocation      Location            @relation("PickupLocationRelations", fields: [pickupLocationId], references: [id])
  
  dropOffLocationId   String
  dropOffLocation     Location            @relation("DropOffLocationRelations", fields: [dropOffLocationId], references: [id])
  
  vehicleCategory     VehicleCategory?
  vehicleId           String?
  vehicle             Vehicle?            @relation(fields: [vehicleId], references: [id])
  
  chargeType          ChargeType          @default(FIXED)
  amount              Decimal             @db.Decimal(10, 2)
  seasonalMultiplier  Decimal?            @db.Decimal(10, 2)
  
  status              DropOffChargeStatus @default(ACTIVE)
  
  isDeleted           Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map("drop_off_charges")
}

enum ChargeType {
  FIXED
  PER_KM
}

enum DropOffChargeStatus {
  ACTIVE
  INACTIVE
}

model SystemSetting {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  description   String?
  updatedAt     DateTime @updatedAt

  @@map("system_settings")
}

model Booking {
  id                String   @id @default(uuid())
  referenceId       String   @unique // e.g., UC2026-4812
  
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  vehicleId         String
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  
  assignedDriverId  String?
  assignedDriver    Driver?  @relation(fields: [assignedDriverId], references: [id])
  
  pickupLocationId  String
  pickupLocation    Location @relation("BookingPickupLocation", fields: [pickupLocationId], references: [id])
  
  dropOffLocationId String
  dropOffLocation   Location @relation("BookingDropOffLocation", fields: [dropOffLocationId], references: [id])
  
  pickupDate        DateTime
  dropOffDate       DateTime
  
  // Pricing Breakdown
  rentalCost        Decimal  @db.Decimal(10, 2)
  pickupFee         Decimal  @db.Decimal(10, 2)
  dropOffFee        Decimal  @db.Decimal(10, 2)
  
  // Add-ons & Extras (Flags)
  hasGps                Boolean @default(false)
  hasFullInsurance      Boolean @default(false)
  hasAdditionalDriver   Boolean @default(false)
  hasChildSeat          Boolean @default(false)
  addonsCost            Decimal @db.Decimal(10, 2) @default(0.00)

  modificationFee   Decimal  @db.Decimal(10, 2) @default(0.00)
  taxPercentage     Decimal  @db.Decimal(5, 2)  @default(16.00)
  taxAmount         Decimal  @db.Decimal(10, 2)
  totalAmount       Decimal  @db.Decimal(10, 2)
  amountPaid        Decimal  @db.Decimal(10, 2) @default(0.00)
  
  // Status
  paymentStatus     PaymentStatus @default(PENDING)
  bookingStatus     BookingStatus @default(PENDING)
  
  // Associated Details
  driverDetails     BookingDriverDetail?
  billingInfo       BillingInfo?
  payments          Payment[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("bookings")
}

model BookingDriverDetail {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  firstName   String
  lastName    String
  email       String
  phone       String
  dateOfBirth DateTime?
  message     String?

  @@map("booking_driver_details")
}

model BillingInfo {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  firstName   String
  lastName    String
  email       String
  phone       String
  address     String
  city        String
  state       String?
  country     String
  zipCode     String?
  description String?

  @@map("billing_infos")
}

model Payment {
  id                String   @id @default(uuid())
  bookingId         String
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  amount            Decimal  @db.Decimal(10, 2)
  paymentMethod     PaymentMethod // MPESA, AIRTEL, CARD, PESAPAL
  transactionId     String?  @unique
  paymentStatus     PaymentStatus @default(PENDING)
  paymentType       String   @default("INITIAL") // INITIAL, EXTENSION, MODIFICATION
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("payments")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  AIRTEL
  CARD
  PESAPAL
}

model Pricing {
  id                        String    @id @default(uuid())
  vehicleId                 String?   @unique
  vehicle                   Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  dailyRate                 Decimal   @db.Decimal(10, 2)
  weeklyRate                Decimal   @db.Decimal(10, 2)
  monthlyRate               Decimal   @db.Decimal(10, 2)
  
  selfDriveRate             Decimal   @db.Decimal(10, 2)
  chauffeurRate             Decimal   @db.Decimal(10, 2)
  seasonalMultiplier        Decimal   @db.Decimal(10, 2) @default(1.0)
  
  extraDayCharge            Decimal   @db.Decimal(10, 2)
  lateReturnHourlyCharge    Decimal   @db.Decimal(10, 2)
  securityDeposit           Decimal   @db.Decimal(10, 2)
  deliveryCollectionCharge  Decimal   @db.Decimal(10, 2)
  airportPickupDropCharge   Decimal   @db.Decimal(10, 2)
  extraMileageCharge        Decimal   @db.Decimal(10, 2)
  
  gpsCharge                 Decimal   @db.Decimal(10, 2) @default(10.00)
  fullInsuranceCharge       Decimal   @db.Decimal(10, 2) @default(20.00)
  additionalDriverCharge    Decimal   @db.Decimal(10, 2) @default(15.00)
  childSeatCharge           Decimal   @db.Decimal(10, 2) @default(5.00)

  discountPercentage        Decimal   @db.Decimal(5, 2) @default(0.00)
  discountValidUntil        DateTime?
  
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@map("pricings")
}
